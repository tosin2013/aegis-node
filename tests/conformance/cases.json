      "expected": "deny"
    },
    {
      "name": "allowlist_match_host_port_protocol",
      "manifest": "manifests/network-allowlist.manifest.yaml",
      "query": { "kind": "network_outbound", "host": "api.example.com", "port": 443, "protocol": "https" },
